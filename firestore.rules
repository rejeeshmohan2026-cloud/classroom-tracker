// firestore.rules
//
// Security rules for Classroom Tracker's Firestore database.
//
// How to apply these:
//   Option A (Firebase Console): Firestore Database -> Rules tab ->
//     paste this file's contents -> Publish.
//   Option B (Firebase CLI): reference this file as "firestore.rules"
//     in firebase.json, then run `firebase deploy --only firestore:rules`.
//
// ---------------------------------------------------------------------
// Real multi-teacher collaboration (this phase)
// ---------------------------------------------------------------------
//
// Classrooms are now shared documents at classrooms/{classroomId} —
// any member listed in that document's `memberUids` array can read and
// write it (see services/memberService.js for the roles: owner,
// teacher, viewer). A teacher's list of accessible classrooms is a
// separate pointer collection, users/{uid}/classroomRefs, which only
// that uid can read or write.
//
// What this enforces:
//   - Only a member of a classroom (their uid is in its `memberUids`
//     array) can read or write it at all.
//   - Only the classroom's stated owner (ownerUid) can create it in the
//     first place, or delete it.
//   - A teacher can only read/write their own classroomRefs and users
//     documents (used for the one-time migration flag) — never anyone
//     else's.
//   - The old teachers/{uid}/classrooms/ location from before sharing
//     existed is kept read/delete-able by its original owner ONLY —
//     needed for the one-time migration in
//     services/workspaceService.js, which reads then deletes from
//     there. Nothing new is ever written to this location.
//
// KNOWN SIMPLIFICATION (see Phase 1 explanation in project history):
// `update` here does not yet distinguish "teacher" from "viewer" — any
// current member can write. A viewer being unable to write, and a
// teacher being unable to edit `members`/`ownerUid`/`memberUids`
// directly, are follow-up hardening for when the viewer role and
// invitations actually ship, not implemented yet.

// ---------------------------------------------------------------------
// "Join a Classroom" (co-teacher self-service, via a shared code)
// ---------------------------------------------------------------------
//
// PROPOSED — added alongside the client code that needs it
// (repositories/firestoreClassroomRepository.js's createJoinCodeMapping/
// getClassroomIdByJoinCode/addSelfAsTeacher), but not yet verified
// against a real Firestore project: this sandboxed environment has no
// real Firebase credentials, so every other rule change in this
// project's history could be tested end-to-end — this one could not.
// Please review and test this specifically before deploying, the same
// way you would for any other security-rule change.
//
// The problem this solves: a co-teacher isn't a member of the
// classroom they're trying to join yet, so the existing `allow read`
// rule above (member-only) can't help them find it, and a query across
// `classrooms` filtered by join code would be denied for the same
// reason. Two additions, kept as narrow as possible:
//
//   1. A new joinCodes/{code} collection — a tiny, low-sensitivity
//      lookup (`{ classroomId: "..." }`) that reveals only an opaque
//      classroom id for a known code, nothing about the classroom's
//      actual content (no student names, no scores, nothing). Readable
//      by any signed-in user; write-once (create, never update/delete)
//      so a code can't be silently repointed at a different classroom
//      after being shared.
//
//   2. classrooms/{classroomId}'s `allow update` rule gains a second
//      path: a non-member may write, but ONLY if the resulting document
//      still has every field identical to before except their own
//      uid being added to `memberUids` and `members` — they cannot
//      touch scores, students, settings, ownerUid, or remove/modify
//      any other member's entry. This is exactly why
//      addSelfAsTeacher() was written as a narrow, additive-only update
//      (arrayUnion + a single new map key) rather than a full document
//      overwrite: a rule permitting "add exactly your own uid" is
//      possible to write safely; a rule permitting "a non-member may
//      write anything" is not.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classroomId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerUid &&
        request.auth.uid in request.resource.data.memberUids;

      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberUids ||
        isSelfOnlyJoin(request, resource)
      );

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
    }

    match /joinCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /classroomRefs/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Legacy, pre-sharing location — migration-only (see
    // services/workspaceService.js). Nothing new is ever written here.
    match /teachers/{teacherId}/classrooms/{classroomId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // Everything else is denied by default (Firestore rules are
    // deny-by-default outside of explicit `match` blocks), but this is
    // here for clarity and as a deliberate backstop.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// A non-member may update a classroom ONLY to add exactly their own
// uid to memberUids/members — nothing else may change. Every other
// top-level field (teams, notebooks, settings, learningActivities,
// ownerUid, classroomJoinCode, etc.) must be byte-for-byte identical
// to what it was before the write.
function isSelfOnlyJoin(request, resource) {
  return request.auth.uid in request.resource.data.memberUids &&
    !(request.auth.uid in resource.data.memberUids) &&
    request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1 &&
    request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid]) &&
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberUids']);
}
